{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Admin or Cashier)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "cashier"] },
        "name": { "type": "string" }
      },
      "required": ["id", "username", "role", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "A menu item available for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Coffee", "Non-Coffee", "Food", "Snack", "Pastry"] },
        "price": { "type": "number" },
        "isReady": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "price", "isReady"]
    },
    "Discount": {
      "title": "Discount",
      "description": "Promotion applied to sales",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "minPurchase": { "type": "number" }
      },
      "required": ["id", "name", "value", "type", "startDate", "endDate"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "note": { "type": "string" },
              "total": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "discountAmount": { "type": "number" },
        "discountName": { "type": "string" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "non-cash"] },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "customerName": { "type": "string" }
      },
      "required": ["id", "timestamp", "items", "subtotal", "discountAmount", "tax", "total", "paymentMethod", "userId", "userName", "customerName"]
    },
    "InventoryLog": {
      "title": "Inventory Log",
      "description": "Record of stock changes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "change": { "type": "number" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "productName", "change", "reason", "timestamp"]
    },
    "PaymentMethod": {
      "title": "Payment Method",
      "description": "Available methods for payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["cash", "non-cash"] },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "type", "isActive"]
    },
    "CafeSettings": {
      "title": "Cafe Settings",
      "description": "Global configuration for the cafe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "currency": { "type": "string" },
        "taxRate": { "type": "number" }
      },
      "required": ["id", "name", "logoUrl", "primaryColor", "secondaryColor", "address", "phone", "currency", "taxRate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "General user profile"
    },
    "/users/{userId}/products/{productId}": {
      "schema": "Product",
      "description": "User's menu products"
    },
    "/users/{userId}/discounts/{discountId}": {
      "schema": "Discount",
      "description": "User's active promotions"
    },
    "/users/{userId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "User's completed sales"
    },
    "/users/{userId}/inventoryLogs/{logId}": {
      "schema": "InventoryLog",
      "description": "User's inventory history"
    },
    "/users/{userId}/payment_methods/{methodId}": {
      "schema": "PaymentMethod",
      "description": "User's payment options"
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": "CafeSettings",
      "description": "User's cafe configuration"
    }
  }
}
